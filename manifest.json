{
  "manifest_version": 3,
  "name": "Lead Scraper",
  "version": "1.0",
  "description": "Free lead scraper — type any search, get a CSV with names, phones, emails & hours",
  "permissions": ["storage", "downloads", "tabs", "scripting"],
  "host_permissions": [
    "https://www.google.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lead Scraper"
  },
  "background": {
    "service_worker": "background.js"
  }
}
